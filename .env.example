# =============================================================================
# OrcaQ — Environment Variables
# Copy this file to .env and customize as needed
# =============================================================================

# --- OrcaQ Application ---
ORCAQ_PORT=3000

# --- Demo PostgreSQL (included for testing) ---
POSTGRES_PORT=5432
POSTGRES_USER=orcaq
POSTGRES_PASSWORD=orcaq_demo_pass
POSTGRES_DB=orcaq_demo

# --- AI Provider API Keys (all optional — enable AI features in OrcaQ) ---
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_GENERATIVE_AI_API_KEY=AIza...
# XAI_API_KEY=xai-...
# OPENROUTER_API_KEY=sk-or-...

# --- Analytics (optional) ---
# NUXT_AMPLITUDE_API_KEY=
